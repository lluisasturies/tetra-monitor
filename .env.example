# Copia este archivo como .env y rellena los valores reales
# El archivo .env NUNCA debe subirse a git (está en .gitignore)

DB_USER=piuser
DB_PASSWORD=pipassword

TELEGRAM_TOKEN=tu_token_de_bot
TELEGRAM_CHAT_ID=tu_chat_id

# Genera un secreto seguro con: openssl rand -hex 32
JWT_SECRET=genera_un_secreto_largo_y_aleatorio_aqui

# Usuario para obtener tokens JWT
API_USER=admin

# Hash bcrypt de la contraseña de la API
# Genera el hash con: make set-password
API_PASSWORD_HASH=$2b$12$reemplaza_esto_con_el_hash_generado

# Orígenes permitidos para CORS (separados por coma)
# Ejemplo: http://192.168.1.100:3000,https://mi-panel.local
# Si no se define, solo se permite http://localhost
CORS_ORIGINS=
