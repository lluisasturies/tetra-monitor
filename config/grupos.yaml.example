# Catalogo de grupos TETRA, carpetas y listas de escaneo.
# Copia este fichero y renombralo:
#   cp config/grupos.yaml.example config/grupos.yaml
#
# IMPORTANTE: Este fichero se usa SOLO como semilla en el primer arranque.
# Si la tabla 'grupos' ya tiene datos, este fichero se ignora.
# A partir del primer arranque el catalogo se gestiona desde la BD via API.

grupos:
  - nombre: "Operaciones"
    gssi: 36001
  - nombre: "Emergencias"
    gssi: 36002
  - nombre: "Logistica"
    gssi: 36003
  - nombre: "Seguridad"
    gssi: 36004

# Carpetas organizativas (equivalente a las folders de la radio).
# Un GSSI puede aparecer en varias carpetas.
carpetas:
  - nombre: "Operativo"
    grupos: [36001, 36003]
  - nombre: "Emergencias"
    grupos: [36002, 36004]

# Scan Lists - listas de escaneo.
# Indican a la radio varios grupos para afiliarse simultaneamente.
scan_lists:
  - nombre: "ListaScan1"
    grupos: [36001, 36002, 36003]
  - nombre: "Emergencias"
    grupos: [36002, 36004]
